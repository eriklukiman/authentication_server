{
  "name": "image-browser-app",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false --browsers=ChromeHeadless",
    "build:dist": "bun run ng build --configuration=dist",
    "build:tagging": "bun run ng build --configuration=tagging",
    "build:prod": "bun run ng build --configuration=production",
    "build:dev": "bun run ng build --configuration=development"
  },
  "dependencies": {
    "@angular/animations": "21.2.9",
    "@angular/common": "21.2.9",
    "@angular/compiler": "21.2.9",
    "@angular/core": "21.2.9",
    "@angular/forms": "21.2.9",
    "@angular/platform-browser": "21.2.9",
    "@angular/router": "21.2.9",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@angular/build": "21.2.7",
    "@angular/cli": "21.2.7",
    "@angular/compiler-cli": "21.2.9",
    "@angular/platform-browser-dynamic": "21.2.9",
    "@types/jasmine": "6.0.0",
    "jasmine-core": "6.2.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.2.0",
    "typescript": "6.0.3"
  }
}